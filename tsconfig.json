{
  "compilerOptions": {
    "lib": ["ESNext"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "resolveJsonModule": true,
    "importsNotUsedAsValues": "remove",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": false,
    "incremental": false,
    "allowJs": true,
    "skipLibCheck": true,
    "importHelpers": true,
    "maxNodeModuleJsDepth": 2,
    "declaration": false,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src/**/*"]
}
